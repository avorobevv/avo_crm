#!/usr/bin/env bash
set -euo pipefail

ROOT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
MODE="${1:-start}"

cd "$ROOT_DIR"

case "$MODE" in
  dev)
    exec npm run dev
    ;;
  start)
    exec npm run start
    ;;
  *)
    echo "Usage: personal-crm [start|dev]" >&2
    exit 1
    ;;
esac
